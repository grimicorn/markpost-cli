{
  "name": "@markpost/cli",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "bin": {
    "markpost": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "watch": "tsc --watch & tsc-alias --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:ui": "npm run test -- --ui",
    "lint": "prettier --check ./src && eslint ./src",
    "lint:fix": "prettier --write ./src && eslint --fix ./src",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "tsc-alias": "^1.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@sindresorhus/slugify": "^3.0.0",
    "chalk": "^5.6.2",
    "cli-spinners": "^3.4.0",
    "conf": "^15.1.0",
    "yocto-spinner": "^1.2.0"
  }
}
