    "prettier": "^3.8.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@sindresorhus/slugify": "^3.0.0",
